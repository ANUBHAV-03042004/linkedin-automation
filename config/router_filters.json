{
  "note": "Use formatDate(now; 'e') in Make.com filter conditions. Returns 1=Mon through 7=Sun.",
  "make_function": "{{formatDate(now; \"e\")}}",
  "routes": [
    {
      "label": "Text Day",
      "condition_variable": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [1, 2],
      "days": ["Monday", "Tuesday"],
      "post_type": "text"
    },
    {
      "label": "Image Day",
      "condition_variable": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [3, 4],
      "days": ["Wednesday", "Thursday"],
      "post_type": "image"
    },
    {
      "label": "Poll Day",
      "condition_variable": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [5, 6],
      "days": ["Friday", "Saturday"],
      "post_type": "poll"
    },
    {
      "label": "Video Day",
      "condition_variable": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [7],
      "days": ["Sunday"],
      "post_type": "video"
    }
  ],
  "day_map": {
    "1": "Monday",
    "2": "Tuesday",
    "3": "Wednesday",
    "4": "Thursday",
    "5": "Friday",
    "6": "Saturday",
    "7": "Sunday"
  }
}
