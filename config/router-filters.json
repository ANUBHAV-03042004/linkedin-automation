{
  "name": "Router — day-of-week filter conditions",
  "make_function": "formatDate(now; \"e\")",
  "note": "Make.com formatDate with 'e' returns 1=Monday through 7=Sunday",
  "routes": [
    {
      "label": "Text Day",
      "filter": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [1, 2],
      "days": ["Monday", "Tuesday"],
      "output": "LinkedIn text post"
    },
    {
      "label": "Image Day",
      "filter": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [3, 4],
      "days": ["Wednesday", "Thursday"],
      "output": "NVIDIA → ImgBB → LinkedIn image post"
    },
    {
      "label": "Poll Day",
      "filter": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [5, 6],
      "days": ["Friday", "Saturday"],
      "output": "Poll gen → LinkedIn poll post"
    },
    {
      "label": "Video Day",
      "filter": "{{formatDate(now; \"e\")}}",
      "operator": "equal to",
      "values": [7],
      "days": ["Sunday"],
      "output": "BGM → Freepik → json2video → Sleep → GET → LinkedIn video post"
    }
  ]
}
